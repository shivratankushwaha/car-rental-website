PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret

# MySQL configuration. Run `npm run seed` after creating your .env.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=car_rental_db

# Set true if you want to preview without MySQL.
USE_MEMORY_STORE=false
MYSQL_REQUIRED=false

# Optional ImageKit fields if you later wire uploads to ImageKit.
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
